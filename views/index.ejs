<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/css/style.css">

  <link rel="apple-touch-icon" sizes="180x180" href="/assets/icons/apple-touch-icon.png">
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/icons/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/assets/icons/favicon-16x16.png">
  <link rel="manifest" href="/assets/icons/site.webmanifest">
  <title>PadelPlanner</title>
</head>

<div class="page-header">
  <div class="page-header-left">
    <p class="eyebrow">Padel • TSG Rohrbach</p>
    <h1>Verfügbare Courts</h1>
    <p class="page-description">
      Such dir einfach einen Tag aus und trag dich ein!
    </p>
  </div>
  <div class="user-actions">
    <p class="user-info">Angemeldet als <strong><%= user %></strong></p>
    <a href="/logout" class="logout-button">Logout</a>
  </div>
</div>

<div class="page-content">
  <section class="section-card calendar-panel">
    <div class="section-header">
      <h2>Kalender</h2>
    </div>

    <div class="calendar-wrapper">
      <div class="calendar-header">
        <button id="prev-month" type="button">&lt;</button>
        <h3 id="calendar-month"></h3>
        <button id="next-month" type="button">&gt;</button>
      </div>

      <div class="calendar-weekdays">
        <div>Mo</div>
        <div>Di</div>
        <div>Mi</div>
        <div>Do</div>
        <div>Fr</div>
        <div>Sa</div>
        <div>So</div>
      </div>

      <div id="calendar" class="calendar"></div>
    </div>

    <div class="legend">
      <button class="legend-item available" data-filter="available" type="button">frei</button>
      <button class="legend-item booked" data-filter="booked" type="button">teilbelegt</button>
      <button class="legend-item full" data-filter="full" type="button">voll</button>
    </div>
  </section>

  <section class="section-card slot-panel">
    <div class="section-header">
      <h2 id="selected-date-title">Wähle einen Tag</h2>
    </div>
    <div id="slot-grid" class="slots-grid">
      <div class="empty-state">Wähle oben einen Tag aus, um die verfügbaren Slots anzuzeigen.</div>
    </div>
  </section>
</div>

<script>
  window.slotData = <%- JSON.stringify(slots) %>;
</script>
<script src="/js/app.js"></script>