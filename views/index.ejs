<head>
  <link rel="stylesheet" href="/css/style.css">
</head>

<h1>Padel Buchungen - <%= user %></h1>

<% 
  const groupedSlots = slots.reduce((acc, slot) => {
    if (!acc[slot.date]) acc[slot.date] = [];
    acc[slot.date].push(slot);
    return acc;
  }, {});
%>

<% Object.keys(groupedSlots).sort((a, b) => new Date(a) - new Date(b)).forEach(date => { %>
  <h2><%= new Date(date).toLocaleDateString('de-DE') %></h2>
  <div class="slots-grid">
    <% groupedSlots[date].forEach(slot => { %>
      <% 
        const isFull = slot.booking_count >= 4;
        const hasBookings = slot.booking_count > 0;
        const isBookedByUser = slot.user_booked;
        let className = 'slot-button';

        if (isFull) className += ' full';
        else if (hasBookings) className += ' booked';
        else className += ' available';

        if (isBookedByUser) className += ' user-booked'; // Zusätzliche Klasse

        const icon = isBookedByUser ? ' ✓' : '';
        const tooltip = slot.booked_users
          ? `Gebucht: ${slot.booked_users}`
          : 'Noch keine Buchungen';
        const disabled = isFull;
      %>
      <button
        type="button"
        class="<%= className %>"
        title="<%= tooltip %>"
        <%= disabled ? 'disabled' : '' %>
        onclick="<%= disabled ? '' : `bookSlot(${slot.id})` %>">
        <%= slot.start_time_formatted %> - <%= slot.end_time_formatted %> (<%= slot.booking_count %>/4)<%= icon %>
      </button>
    <% }); %>
  </div>
<% }); %>

<script src="/js/app.js"></script>