<head>
  <link rel="stylesheet" href="/css/style.css">
</head>

<header class="page-header">
  <h1>Padel TSG Rohrbach</h1>
  <div class="user-actions">
    <p class="user-info">Angemeldet als <strong><%= user %></strong></p>
    <a href="/logout" class="logout-button">Logout</a>
  </div>
</header>

<div class="calendar-wrapper">
  <div class="calendar-header">
    <button id="prev-month" type="button">&lt;</button>
    <h2 id="calendar-month"></h2>
    <button id="next-month" type="button">&gt;</button>
  </div>

  <div class="calendar-weekdays">
    <div>Mo</div>
    <div>Di</div>
    <div>Mi</div>
    <div>Do</div>
    <div>Fr</div>
    <div>Sa</div>
    <div>So</div>
  </div>

  <div id="calendar" class="calendar"></div>
</div>

<div class="legend">
  <span class="legend-item available">Noch frei</span>
  <span class="legend-item booked">Gebucht</span>
  <span class="legend-item full">Voll</span>
</div>

<div id="slot-details">
  <h2 id="selected-date-title"></h2>
  <div id="slot-grid" class="slots-grid"></div>
</div>

<script>
  window.slotData = <%- JSON.stringify(slots) %>;
</script>
<script src="/js/app.js"></script>